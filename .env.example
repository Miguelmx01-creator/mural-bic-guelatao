# ────────────────────────────────────────────────────────────
# Firebase — SDK de cliente (seguro exponer con NEXT_PUBLIC_)
# Consola: Project settings → General → Your apps → SDK setup
# ────────────────────────────────────────────────────────────
NEXT_PUBLIC_FIREBASE_API_KEY=AIzaSy_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=tu-proyecto.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=tu-proyecto
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=tu-proyecto.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=123456789012
NEXT_PUBLIC_FIREBASE_APP_ID=1:123456789012:web:abcdef0123456789

# ────────────────────────────────────────────────────────────
# Firebase — Admin SDK (SERVIDOR ÚNICAMENTE, NUNCA NEXT_PUBLIC_)
# Consola: Project settings → Service accounts → Generate new private key
# Del JSON descargado, copia project_id, client_email y private_key
# ────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=tu-proyecto
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tu-proyecto.iam.gserviceaccount.com
# La clave privada tiene saltos de línea — en Vercel pégala tal cual (con las -----BEGIN...-----)
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIEvQIBADANBgkqhkiG9w0BAQEFAASC...\n-----END PRIVATE KEY-----\n"

# ────────────────────────────────────────────────────────────
# Cloudinary — el preset DEBE ser de tipo "Unsigned"
# Consola: Settings → Upload → Upload presets → Add upload preset
# ────────────────────────────────────────────────────────────
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=tu-cloud-name
NEXT_PUBLIC_CLOUDINARY_UPLOAD_PRESET=mural-bic-preset

# ────────────────────────────────────────────────────────────
# Moderación — PIN del profesor (NUNCA NEXT_PUBLIC_)
# El navegador NUNCA ve este valor; se valida solo en el servidor
# ────────────────────────────────────────────────────────────
MODERATOR_PIN=elige-un-pin-secreto
