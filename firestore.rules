rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /tarjetas/{docId} {
      // Cualquiera puede leer y crear tarjetas (sin login)
      allow read:   if true;
      allow create: if true;

      // Borrar y editar SOLO via Admin SDK (API route /api/moderar)
      // El Admin SDK bypasa estas reglas, los clientes no pueden
      allow update, delete: if false;
    }

    match /jugadores_sierra/{docId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll([
            'nombreCompleto', 'semestre', 'puntaje', 'nivelActual', 'creadoEn'
          ])
          && request.resource.data.nombreCompleto is string
          && request.resource.data.nombreCompleto.size() > 0
          && request.resource.data.nombreCompleto.size() <= 120
          && request.resource.data.semestre in ['Segundo', 'Cuarto', 'Sexto']
          && request.resource.data.puntaje == 0
          && request.resource.data.nivelActual == 1;
      // Actualizaciones de puntaje solo via Admin SDK (igual que tarjetas)
      allow update, delete: if false;
    }

    match /comentarios/{docId} {
      allow read: if true;
      allow create: if request.resource.data.keys().hasAll([
          'comunidadKey', 'autor', 'texto', 'editToken', 'creadoEn', 'editadoEn'
        ])
        && request.resource.data.autor is string
        && request.resource.data.autor.size() > 0
        && request.resource.data.autor.size() <= 80
        && request.resource.data.texto is string
        && request.resource.data.texto.size() > 0
        && request.resource.data.texto.size() <= 500
        && request.resource.data.comunidadKey is string
        && request.resource.data.comunidadKey.size() > 0
        && request.resource.data.editToken is string
        && request.resource.data.editToken.size() >= 20;
      // Editar/borrar solo via Admin SDK (/api/comentarios)
      allow update, delete: if false;
    }

  }
}
